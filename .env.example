# Better Auth
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# App URL with no trailing slash
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave blank to hide/disable Google sign-in)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Cloud Console (OAuth client) ---
#
# Authorized redirect URIs:
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   e.g. http://localhost:3000/api/auth/callback/google
#   e.g. https://your-domain.com/api/auth/callback/google
#
# Authorized JavaScript origins:
#   {BETTER_AUTH_URL}
#   e.g. http://localhost:3000

# Lemon Squeezy (optional until you enable billing)
# API key: https://app.lemonsqueezy.com/settings/api
# Store ID: Settings → Stores
# Variant ID: product variant you want as the default subscription plan
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
# Same signing secret you set when creating the webhook
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Lemon Squeezy webhook ---
#
# Dashboard → Settings → Webhooks
# URL: {BETTER_AUTH_URL}/api/webhooks/lemonsqueezy
# Events (minimum):
#   subscription_created
#   subscription_updated
#   subscription_cancelled
#   subscription_resumed
#   subscription_expired
#   subscription_paused
#   subscription_unpaused
#
# Local testing: expose localhost with ngrok/Cloudflare Tunnel, then point the webhook URL there.
