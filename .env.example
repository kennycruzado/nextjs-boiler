# Google OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Signs session cookies — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL with no trailing slash (local dev example below)
AUTH_URL=http://localhost:3000

# --- Google Cloud Console (OAuth client) ---
#
# Required — Authorized redirect URIs:
#   {AUTH_URL}/api/auth/google/callback
#   e.g. http://localhost:3000/api/auth/google/callback
#   e.g. https://your-domain.com/api/auth/google/callback
#
# Optional for this app — Authorized JavaScript origins:
#   {AUTH_URL} only (no path, no trailing slash)
#   e.g. http://localhost:3000
#   e.g. https://your-domain.com
#
# This project uses server-side OAuth (popup → /api/auth/google → Google → callback).
# You do NOT need javascript: URIs. Redirect URI above is the one that matters.
